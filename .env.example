# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# ---------------------------------------------------------------------------

# --- Supabase ---
# Public values (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secret — used by API routes and Inngest workers to bypass RLS.
# Do NOT prefix with NEXT_PUBLIC_. Get it from Supabase > Project Settings > API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Application URL ---
# Public base URL of the deployed app. Used by background workers to fetch /api/og.
# Local dev can leave this unset (falls back to http://localhost:3000).
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# --- Google / YouTube OAuth ---
YOUTUBE_CLIENT_ID=your-google-oauth-client-id
YOUTUBE_CLIENT_SECRET=your-google-oauth-client-secret
# Must EXACTLY match an Authorized redirect URI in the Google Cloud Console.
# Local dev can leave this unset (falls back to http://localhost:3000/api/auth/callback/google).
GOOGLE_REDIRECT_URI=https://your-app.example.com/api/auth/callback/google

# --- AI providers ---
# Google Gemini is used for transcription and is the default generation provider.
GEMINI_API_KEY=your-gemini-api-key
# Optional — Gemini model used for transcription. Defaults to gemini-2.5-flash.
# Override here if Google retires the model (no code change needed).
GEMINI_MODEL=gemini-2.5-flash
# --- AI Thumbnail pipeline (Art Director → scene → composite → QC) ---
# All default sensibly; override only if a provider renames a model.
# Scene image provider: auto | gemini | openai. Default "auto" tries Gemini first
# (cheapest) and falls back to gpt-image-1 on failure. IMPORTANT: Gemini's image
# model is NOT on the free tier (returns 429, limit 0) — until you enable billing
# on the Gemini key, set this to "openai" to skip the wasted Gemini call.
THUMBNAIL_IMAGE_PROVIDER=auto
# Gemini side (brief + QC always use Flash; image uses the native image model):
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_BRIEF_MODEL=gemini-2.5-flash
GEMINI_QC_MODEL=gemini-2.5-flash
# OpenAI side (the engine behind ChatGPT image generation):
OPENAI_IMAGE_MODEL=gpt-image-1
# Face-swap (exact presenter identity). OPTIONAL — without FAL_KEY the pipeline keeps
# the AI-generated face. Get a key at https://fal.ai (Dashboard → API Keys). The real
# presenter face used as the swap source is the latest Kruptoey asset (or the per-video
# reference image if uploaded under Advanced).
FAL_KEY=
FAL_FACESWAP_MODEL=fal-ai/face-swap
# Optional — cap transcription to the first N minutes of audio (faster + cheaper;
# the generation agents only read the first ~15k chars anyway). 0 = full video.
# Only applies to the audio fallback path (caption path returns the full transcript).
TRANSCRIBE_MAX_MINUTES=25
# Optional — caption-first transcription. By default we use YouTube's own captions
# when available (seconds + free) and only fall back to audio+Gemini when there are
# none. Set PREFER_CAPTIONS=0 to always transcribe audio with Gemini.
PREFER_CAPTIONS=
# Optional — preferred caption languages (comma-separated), best match first.
# Defaults to "en,th". Falls back to the video's own language, then any available.
SUBTITLE_LANGS=en,th
# Optional — only required if an ai_personas row uses these providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Phase B brain models (env-overridable so a retired model alias never bricks the
# pipeline). Defaults below are current, fast + high quality. Anthropic is preferred;
# OpenAI is the fallback when ANTHROPIC_API_KEY is absent.
ANTHROPIC_MEGA_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
OPENAI_MEGA_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
# Optional — set to 1 to log per-agent latency + token usage for the Phase B
# multi-agent pipeline (terminal output, prefixed [phaseB]). Leave unset in prod.
PHASE_B_PROFILE=

# --- Inngest (Background Jobs) ---
# LOCAL DEV: set this to 1 and run `npx inngest-cli@latest dev` in a separate terminal.
# Remove this var entirely in production — it disables signature verification.
INNGEST_DEV=1

# PRODUCTION ONLY: get both values from https://app.inngest.com > your app > Keys.
# Leave blank for local dev (INNGEST_DEV=1 bypasses them).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
